# Проект «Агент» — скопируйте в config/.env и заполните.
# Реальный config/.env не коммитьте (он в .gitignore).

# VAPI / Next.js (публичные, вшиваются в клиентский бандл при сборке)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# Если появятся server actions / API routes к вашему backend
NEXT_PUBLIC_API_URL=
