# Только веб-монитор Telegram mini-бота (лёгкий образ для Docker / reverse proxy).
FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    "fastapi>=0.115,<1" \
    "uvicorn[standard]>=0.32,<1" \
    "python-dotenv>=1.0,<2" \
    "itsdangerous>=2.2,<3" \
    "python-multipart>=0.0.9,<1"

COPY monitor_app.py audit_log.py ./

ENV PYTHONUNBUFFERED=1 \
    MONITOR_HOST=0.0.0.0 \
    MONITOR_PORT=8765 \
    MONITOR_DATA_DIR=/app/data

EXPOSE 8765

CMD ["uvicorn", "monitor_app:app", "--host", "0.0.0.0", "--port", "8765"]
