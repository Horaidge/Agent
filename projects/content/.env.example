# Telegram (бот + webhook)
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY_URL=
# Опционально: секрет для заголовка X-Telegram-Bot-Api-Secret-Token при установке webhook
TELEGRAM_WEBHOOK_SECRET=

# Полный HTTPS URL webhook для Telegram (удобно с туннелем), например https://abc.ngrok-free.app/webhook
# Если задан — имеет приоритет над PUBLIC_BASE_URL + WEBHOOK_PATH
TELEGRAM_WEBHOOK_URL=

# Альтернатива TELEGRAM_WEBHOOK_URL: базовый URL туннеля без слэша; итог = PUBLIC_BASE_URL + WEBHOOK_PATH
PUBLIC_BASE_URL=

# Если true — при старте вызвать setWebhook (нужен TELEGRAM_WEBHOOK_URL или PUBLIC_BASE_URL)
SET_WEBHOOK_ON_STARTUP=true

# Автозапуск ngrok вместе с main.py (публичный HTTPS + setWebhook без ручного туннеля)
START_NGROK_TUNNEL=false
# Токен с https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTH_TOKEN=

# Рекомендуемый режим: EMBED_CLOUDFLARE_TUNNEL=false — туннель только в отдельном процессе:
#   терминал 1: python run_cloudflared_tunnel.py
#   терминал 2: python main.py
# Если true — cloudflared поднимается внутри main.py (один процесс).
EMBED_CLOUDFLARE_TUNNEL=false

# Только при EMBED_CLOUDFLARE_TUNNEL=true: принудительно поднять туннель в main (дублирует логику «embed»)
START_CLOUDFLARE_TUNNEL=false
# Секунд ожидания URL (встроенный туннель или появления current_tunnel.txt)
CLOUDFLARE_TUNNEL_TIMEOUT_SEC=60
# Полный путь к cloudflared.exe (Windows: если в PATH попадается пустой фиктивный файл)
# CLOUDFLARED_BIN=C:\Program Files (x86)\cloudflared\cloudflared.exe

# Локальная dev-консоль (только 127.0.0.1): http://127.0.0.1:8000/dev/
DEV_DEBUG_UI=false
# Автоперезапуск uvicorn при изменении кода (локально; в run_dev.sh включается автоматически)
UVICORN_RELOAD=false
# Секрет для API редактирования промптов (GET/PUT /api/prompts/*); тот же ключ задайте во frontend/.env.local
PROMPTS_EDITOR_SECRET=

# HTTP-сервер (FastAPI + webhook + Gradio)
HOST=0.0.0.0
PORT=8000
# Путь на вашем backend (должен совпадать с путём в TELEGRAM_WEBHOOK_URL)
WEBHOOK_PATH=/webhook
GRADIO_MOUNT_PATH=/ui

# Открыть Gradio в браузере после старта (true/false)
OPEN_BROWSER_ON_START=true

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=dream_viz
MONGODB_COLLECTION_MESSAGES=inbound_messages

# OpenAI (чат-агент, tool calling)
OPENAI_API_KEY=
OPENAI_PROXY_URL=
OPENAI_MODEL=gpt-4o-mini

# Qwen Image (Alibaba DashScope): генерация/редактирование изображений
# Ключ из Model Studio; регион должен совпадать с endpoint (intl vs Beijing)
DASHSCOPE_API_KEY=
# По умолчанию сингапурский (international). Пекин: https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# DASHSCOPE_ENDPOINT=https://dashscope-intl.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
