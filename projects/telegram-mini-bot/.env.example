# Мини-бот — единая точка входа (чат + RAG + визуализация снов Dream Lite)
TELEGRAM_BOT_TOKEN=

# OpenAI — можно скопировать из ../content/.env
OPENAI_API_KEY=
# Флагман без «mini», см. docs OpenAI; при ошибке API можно откатить на gpt-4o и т.п.
OPENAI_MODEL=gpt-5.5
# Опционально, если API только через прокси (как в content):
# OPENAI_PROXY_URL=socks5h://user:pass@host:port

# Сайт (для справки / будущего webhook)
PUBLIC_SITE_URL=https://smartagentplatform.ru

# Кто может менять system prompt (Telegram user id через запятую). Пусто = все.
# ADMIN_USER_IDS=123456789

# Supabase (RAG): скопируй из ../content/.env или ~/config/.env
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# Пароль БД (Settings → Database) — для scripts/bootstrap_rag_table.py, не для REST-клиента
# SUPABASE_DB_PASSWORD=
# Если прямой db..supabase.co не доступен (нет IPv6), скрипт сам переберёт pooler; можно задать регион:
# SUPABASE_POOLER_REGION=eu-west-1
# Имя таблицы после применения sql/rag_chunks.sql (по умолчанию):
# SUPABASE_RAG_TABLE=telegram_rag_chunks
# Модель эмбеддингов (должна быть 1536 измерений, как в таблице):
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Сколько чанков подмешивать в контекст (1–50):
# RAG_TOP_K=10
# Полностью отключить RAG в боте: RAG_DISABLED=1

# --- Dream Lite (визуализация снов из projects/content) ---
# Включить пайплайн: DREAM_LITE_ENABLED=1 и рабочий Mongo (как в content/.env)
# DREAM_LITE_ENABLED=1
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=dream_viz
# PUBLIC_BASE_URL=https://smartagentplatform.ru
# CONTENT_PROJECT_ROOT=../content
# Остальные ключи (DashScope/Qwen и т.д.) подтягиваются из content/.env при старте.

# Веб-монитор диалогов (Docker: сервис telegram_bot_monitor)
# Пароль для входа в браузере (форма «Войти»):
# MONITOR_PASSWORD=придумай_надёжный_пароль
# Опционально: отдельный ключ подписи cookie (если не задать — выводится из пароля):
# MONITOR_SESSION_SECRET=
# MONITOR_HOST=127.0.0.1
# MONITOR_PORT=8765
